<Window x:Class="AlconMusicPlayer.WPF.Dialogs.NewPlaylistDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="New Playlist" Height="200" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">
    <StackPanel Margin="16">
        <TextBlock Text="Playlist name:"
                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,8" />
        <TextBox x:Name="NameBox"
                 Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource ForegroundBrush}"
                 BorderBrush="{DynamicResource HoverBrush}" Padding="8,6"
                 KeyDown="NameBox_KeyDown" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Width="75" Margin="0,0,8,0"
                    Click="Cancel_Click"
                    Background="{DynamicResource HoverBrush}" Foreground="{DynamicResource ForegroundBrush}"
                    BorderThickness="0" Padding="8,6" />
            <Button Content="Create" Width="75"
                    Click="Create_Click"
                    Background="{DynamicResource PrimaryActionBrush}" Foreground="{DynamicResource ForegroundBrush}"
                    BorderThickness="0" Padding="8,6" />
        </StackPanel>
    </StackPanel>
</Window>